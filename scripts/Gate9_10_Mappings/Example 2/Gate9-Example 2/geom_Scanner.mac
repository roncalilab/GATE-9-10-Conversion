# World

/gate/world/geometry/setXLength 800. mm
/gate/world/geometry/setYLength 800. mm
/gate/world/geometry/setZLength 2000. mm
/gate/world/vis/forceWireframe
/gate/world/vis/setColor white
#/gate/world/vis/setVisible 1

# Cylindrical PET

/gate/world/daughters/name cylindricalPET
/gate/world/daughters/insert cylinder
/gate/cylindricalPET/setMaterial Air
/gate/cylindricalPET/geometry/setRmax 390 mm
/gate/cylindricalPET/geometry/setRmin 320 mm
/gate/cylindricalPET/geometry/setHeight 1620 mm
/gate/cylindricalPET/vis/forceWireframe
/gate/cylindricalPET/vis/setColor black
#/gate/cylindricalPET/vis/setVisible 0


# rsector: Bundle

/gate/cylindricalPET/daughters/name bundle
/gate/cylindricalPET/daughters/insert box
/gate/bundle/placement/setTranslation 0 350 0 mm
/gate/bundle/geometry/setXLength 16 mm
/gate/bundle/geometry/setYLength 60 mm
/gate/bundle/geometry/setZLength 1620 mm
/gate/bundle/setMaterial Air
/gate/bundle/vis/setColor red
/gate/bundle/vis/forceWireframe
/gate/bundle/vis/setVisible 1


# module: fibre

/gate/bundle/daughters/name fibre
/gate/bundle/daughters/insert box
/gate/fibre/placement/setTranslation 0 0 0 mm
/gate/fibre/geometry/setXLength 4 mm
/gate/fibre/geometry/setYLength 4 mm
/gate/fibre/geometry/setZLength 1600 mm
/gate/fibre/setMaterial EJ230
/gate/fibre/vis/setColor blue
/gate/fibre/vis/forceWireframe
/gate/fibre/vis/setVisible 0



# PMTS
#/gate/bundle/daughters/name pmt1
