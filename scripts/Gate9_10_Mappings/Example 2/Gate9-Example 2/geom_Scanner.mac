#/gate/pmt2/vis/setVisible 0

# Repeat rsector

/gate/bundle/repeaters/insert ring
/gate/bundle/ring/setRepeatNumber 125


# Repeat module
/gate/fibre/repeaters/insert cubicArray
/gate/fibre/cubicArray/setRepeatNumberX 4
/gate/fibre/cubicArray/setRepeatNumberY 15
/gate/fibre/cubicArray/setRepeatNumberZ 1
/gate/fibre/cubicArray/setRepeatVector 4. 4. 0. mm


# Repeat PMT
#/gate/pmt1/repeaters/insert cubicArray
#/gate/pmt1/cubicArray/setRepeatNumberX 4
#/gate/pmt1/cubicArray/setRepeatNumberY 4
#/gate/pmt1/cubicArray/setRepeatNumberZ 1
#/gate/pmt1/cubicArray/setRepeatVector 4. 4. 0. mm

#/gate/pmt2/repeaters/insert cubicArray
#/gate/pmt2/cubicArray/setRepeatNumberX 4
#/gate/pmt2/cubicArray/setRepeatNumberY 4
#/gate/pmt2/cubicArray/setRepeatNumberZ 1
